---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Icon from "../components/Icon.astro";
import { SITE } from "../lib/blog-data.js";
import { sendMail } from "../lib/sendMail.js";
---

<BaseLayout
  title={`Contact - ${SITE.name}`}
  description={`Get in touch with ${SITE.name}.`}
  canonical="/contact"
>
  <div class="mx-auto max-w-3xl px-5 py-12">
    <Breadcrumbs items={[{ label: "Trang chủ", to: "/" }, { label: "Liên lạc" }]} />

    <header class="mt-6">
      <div class="text-xs font-medium uppercase tracking-[0.2em] text-primary">Liên lạc</div>
      <h1 class="mt-2 font-serif text-5xl font-semibold tracking-tight">Gửi lời chào.</h1>
      <p class="mt-4 max-w-xl text-muted-foreground">
       Hãy để lại những chia sẻ những góp ý chúng tôi sẽ đọc và trả lời bạn tất cả.
      </p>
    </header>

    <div class="mt-12 grid gap-12 lg:grid-cols-[1fr_240px]">
      <form data-contact-form class="space-y-5">
        <div>
          <label for="name" class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Tên</label>
          <input id="name"name="name" required class="mt-2 w-full border-0 border-b border-input bg-transparent py-2 text-base outline-none focus:border-primary" />
        </div>
        <div>
          <label for="email" class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Email</label>
          <input id="email" name="email" type="email" required class="mt-2 w-full border-0 border-b border-input bg-transparent py-2 text-base outline-none focus:border-primary" />
        </div>
        <div>
          <label for="message" class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Tin nhắn</label>
          <textarea id="message" name="message" required rows="6" class="mt-2 w-full border-0 border-b border-input bg-transparent py-2 text-base outline-none focus:border-primary"></textarea>
        </div>
        <div class="cf-turnstile mt-4" data-sitekey="0x4AAAAAADv6rZtTPI4p6odvs">
        </div>
        <button type="submit" class="rounded-md bg-foreground px-6 py-2.5 text-sm font-medium text-background hover:opacity-90">
          Gửi
        </button>
        <p data-contact-sent class="text-sm text-primary" role="status" hidden>Cám ơn &mdash; chúng tôi sẽ phản hồi nhanh nhất.</p>
      </form>

      <aside class="space-y-6 border-l border-border pl-8 lg:block">
        <div>
          <div class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Kết nối</div>
          <ul class="mt-3 space-y-3 text-sm">
            <li><a href="mailto:phuc@namkyxua.com" class="flex items-center gap-2 hover:text-primary"><Icon name="mail" class="h-3.5 w-3.5" /> phuc@namkyxua.com</a></li>
            <li><a href="https://x.com/p__lux" class="flex items-center gap-2 hover:text-primary"><Icon name="twitter" class="h-3.5 w-3.5" /> @p__lux</a></li>
            <li><a href="/rss.xml" class="flex items-center gap-2 hover:text-primary"><Icon name="rss" class="h-3.5 w-3.5" /> RSS feed</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script>
const contactForm = document.querySelector("[data-contact-form]");
const sent = document.querySelector("[data-contact-sent]");

contactForm?.addEventListener("submit", async (event) => {
  event.preventDefault();

  if (sent) {
    sent.hidden = true;
    sent.textContent = "";
  }

  const formData = new FormData(contactForm);

  const data = {
    name: formData.get("name"),
    email: formData.get("email"),
    message: formData.get("message"),

    title: document.title,
    link: window.location.href,
    token: formData.get("cf-turnstile-response"),
  };

  try {
    const response = await fetch("https://namkyxua.com/api/contact", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(data),
    });

    const result = await response.json();

    if (result.status === "success") {
      contactForm.reset();

      if (sent) {
        sent.hidden = false;
        sent.textContent = "Cám ơn - chúng tôi sẽ phản hồi nhanh nhất.";
      }
    } else {
      if (sent) {
        sent.hidden = false;
        sent.textContent = result.message || "Không gửi được.";
      }
    }
  } catch (err) {
    if (sent) {
      sent.hidden = false;
      sent.textContent = "Có lỗi xảy ra. Vui lòng thử lại.";
    }

    console.error(err);
  }
});
</script>
