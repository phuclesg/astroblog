---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PostCard from "../../components/PostCard.astro";
import Icon from "@/components/Icon.astro";

// Import trực tiếp từ blog-data.js của ông
import { postsByCategory, tags, getTag, SITE } from "@/lib/blog-data.js";

// 1. Lấy tất cả bài viết có tag "hinh-anh" 
const galleryPosts = await postsByCategory("hinh-anh");

// 2. Lấy ra danh sách các Tag phụ có trong các bài gallery
const rawSubTagSlugs = [...new Set(
  galleryPosts.flatMap((post) => post.tags || [])
)].filter((slug) => slug !== "hinh-anh");

// 3. Map các slug đó với mảng tags khai báo sẵn trong blog-data.js để lấy Name + Slug
const subTags = rawSubTagSlugs
  .map((slug) => getTag(slug))
  .filter(Boolean); // Bỏ các tag null/undefined nếu lỡ quên khai báo
---

<BaseLayout
  title={`Thư viện ảnh - ${SITE.name}`}
  description="Nơi ký ức nằm trong món ăn, con người và những câu chuyện cũ."
  canonical="/gallery"
>
  <div class="mx-auto max-w-4xl px-5 py-12" data-archive>
    <Breadcrumbs items={[{ label: "Trang chủ", to: "/" }, { label: "Thư viện ảnh" }]} />
    
    <h1 class="mt-4 font-serif text-4xl font-semibold tracking-tight sm:text-5xl">
      Thư viện ảnh
    </h1>
    
    <p class="mt-3 max-w-xl text-muted-foreground">
      Tất cả {galleryPosts.length} bài viết đều dựa trên tư liệu thu thập từ nhiều nguồn khác nhau.
    </p>

    <!-- Ô Tìm kiếm -->
    <form data-archive-search class="mt-8 flex items-center gap-2 border-b border-border pb-2">
      <Icon name="search" class="h-4 w-4 text-muted-foreground" />
      <input
        data-archive-query
        name="q"
        aria-label="Tìm trong bài viết"
        placeholder="Tìm trong bài viết..."
        class="w-full border-0 bg-transparent py-2 outline-none placeholder:text-muted-foreground"
      />
      <button
        data-archive-clear
        type="button"
        class="text-xs text-muted-foreground hover:text-foreground"
        hidden
      >
        Clear
      </button>
    </form>
    {subTags.length > 0 && (
      <div class="mt-6 flex flex-wrap items-center gap-2">
        <span class="text-xs uppercase tracking-wider text-muted-foreground">Tags:</span>
        {subTags.map((tag) => (
          <a
            data-tag-filter={tag.slug}
            href={`/gallery?tag=${tag.slug}`}
            class="rounded-full border border-border px-2.5 py-0.5 text-xs text-muted-foreground hover:border-primary hover:text-foreground transition-colors"
          >
            #{tag.name}
          </a>
        ))}
      </div>
    )}

    <div data-archive-count class="mt-6 text-sm text-muted-foreground"></div>

    <div data-archive-empty class="mt-12 rounded-md border border-dashed border-border py-20 text-center" hidden>
      <div class="font-serif text-lg">Không tìm thấy nội dung nào</div>
      <p class="mt-2 text-sm text-muted-foreground">Hãy thử lại bằng từ khóa khác</p>
    </div>

    <!-- Danh sách Bài viết -->
    <div data-archive-list class="mt-8 space-y-6">
      {galleryPosts.map((post) => (
        <PostCard post={post} variant="list" />
      ))}
    </div>

    <div data-archive-more-wrap class="mt-10 text-center" hidden>
      <button
        type="button"
        data-archive-more
        class="rounded-md border border-border px-5 py-2.5 text-sm font-medium hover:bg-muted"
      ></button>
      <div data-archive-page class="mt-3 text-xs text-muted-foreground"></div>
    </div>
  </div>
</BaseLayout>