---
import { mediaURL } from "@/utils/media.ts"
interface Props {
    src: string;
    alt: string;
    caption: string;
}
const { src, alt, caption} = Astro.props;
---
<figure class="flex items-center flex-col">
    <img src={ mediaURL(src)} alt={alt} loading="lazy" decoding="async" />
    {caption && (
        <figcaption class="text-sm mb-2">{caption}.</figcaption>
    )}
</figure>