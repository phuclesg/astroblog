---
import { mediaURL } from "@/utils/media.ts"
interface Props {
    src: string;
    alt: string;
    caption: string;
    credit: string;
}
const { src, alt, caption, credit} = Astro.props;
---
<figure class="flex items-center flex-col">
    <img src={ mediaURL(src)} alt={alt} loading="lazy" decoding="async" />
    {caption, credit && (
        <figcaption class="text-xs mb-10">{caption}. Nguồn: {credit} </figcaption>
    )}
</figure>